# Acceptance checks — auto-generated by intake
# Run with: intake verify <spec-dir>

checks:
{% for check in checks %}
  - id: {{ check.id }}
    name: "{{ check.name }}"
    type: {{ check.type }}
    required: {{ check.required | lower }}
{% if check.tags %}
    tags:
{% for tag in check.tags %}
      - {{ tag }}
{% endfor %}
{% endif %}
{% if check.type == "command" and check.command %}
    command: "{{ check.command }}"
{% endif %}
{% if check.type == "files_exist" and check.paths %}
    paths:
{% for p in check.paths %}
      - "{{ p }}"
{% endfor %}
{% endif %}
{% if check.type in ["pattern_present", "pattern_absent"] and check.glob %}
    glob: "{{ check.glob }}"
{% endif %}
{% if check.type in ["pattern_present", "pattern_absent"] and check.patterns %}
    patterns:
{% for p in check.patterns %}
      - "{{ p }}"
{% endfor %}
{% endif %}

{% endfor %}
