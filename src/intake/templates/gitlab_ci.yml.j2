# Generated by intake — spec verification for GitLab CI

stages:
  - verify

intake-verify:
  stage: verify
  image: python:3.12-slim
  before_script:
    - pip install intake-ai-cli --quiet
  script:
    - intake validate {{ spec_dir }} --strict
    - intake verify {{ spec_dir }} -p . --format junit -o report.xml
  artifacts:
    when: always
    reports:
      junit: report.xml
    paths:
      - report.xml
    expire_in: 30 days
  rules:
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"
    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH
